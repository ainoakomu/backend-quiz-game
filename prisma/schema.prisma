generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique @db.VarChar(255)
  password  String     @db.VarChar(255)
  name      String     @db.VarChar(100)
  attempts  Attempt[]
  questions Question[]

  @@map("users")
}

model Question {
  id       Int       @id @default(autoincrement())
  question String    @db.VarChar(255)
  answer   String    @db.VarChar(255)
  userId   Int
  imageUrl String?   @db.VarChar(255)
  imagePublicId String?
  attempts Attempt[]
  user     User      @relation(fields: [userId], references: [id], map: "fk_question_user")
  keywords Keyword[] @relation("KeywordToQuestion")

  @@index([userId], map: "fk_question_user")
  @@map("questions")
}

model Keyword {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  questions Question[] @relation("KeywordToQuestion")

  @@map("keywords")
}

model Attempt {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  userId     Int
  questionId Int
  isCorrect  Boolean?
  question   Question @relation(fields: [questionId], references: [id], map: "fk_attempt_question")
  user       User     @relation(fields: [userId], references: [id], map: "fk_attempt_user")

  @@index([questionId], map: "fk_attempt_question")
  @@index([userId], map: "fk_attempt_user")
  @@map("attempts")
}
