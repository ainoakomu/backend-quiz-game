// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model question {
  id       Int       @id @default(autoincrement())
  question    String    @db.VarChar(255)
  answer     String
  keywords Keyword[]

  @@map("questions")
}

model Keyword {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  questions question[]

  @@map("keywords")
}
