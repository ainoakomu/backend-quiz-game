// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int @id @default(autoincrement())
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  name     String @db.VarChar(100)

  questions Question[]
  attempts  Attempt[]

  @@map("users")
}

model Question {
  id       Int @id @default(autoincrement())
  question String @db.VarChar(255)
  answer   String @db.VarChar(255)

  userId   Int
  user     User @relation(fields: [userId], references: [id], map: "fk_question_user")

  keywords Keyword[]
  attempts Attempt[]

  imageUrl String? @db.VarChar(255)

  @@map("questions")
}

model Keyword {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  questions Question[]

  @@map("keywords")
}

model Attempt {
  id         Int @id @default(autoincrement())
  createdAt  DateTime @default(now())
  isCorrect Boolean? 

  userId     Int
  questionId Int

  user     User     @relation(fields: [userId], references: [id], map: "fk_attempt_user")
  question Question @relation(fields: [questionId], references: [id], map: "fk_attempt_question")

  @@map("attempts")
}

