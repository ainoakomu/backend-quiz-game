{
  "name": "backend-quiz-game",
  "version": "1.0.0",
  "description": "A backend focused quiz game",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "DATABASE_URL=mysql://root:password@localhost:3306/quiz_test npx prisma db push --skip-generate",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "ainoakomu",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "streamifier": "^0.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
